# NexusClaw Configuration
# Copie este arquivo para .env e preencha com suas configurações

# ============================================
# Configurações Gerais
# ============================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Chave secreta para sessões (gere uma nova!)
SECRET_KEY=sua-chave-secreta-aqui-mude-isso

# ============================================
# Configurações do Banco de Dados
# ============================================
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexusai

# ============================================
# Configurações de Cache e Filas
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Configurações do LLM (Ollama)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# Fallback com OpenAI (opcional)
OPENAI_API_KEY=sk-sua-chave-aqui
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Fallback com Anthropic (opcional)
ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# ============================================
# Configurações de Memória Vetorial (Qdrant)
# ============================================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=nexus_memories

# Modelo de Embedding
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ============================================
# Canais de Comunicação
# ============================================

# Telegram
TELEGRAM_BOT_TOKEN=seu-token-aqui
TELEGRAM_WEBHOOK_URL=

# Discord
DISCORD_BOT_TOKEN=seu-token-aqui
DISCORD_GUILD_ID=
DISCORD_CHANNEL_IDS=

# WhatsApp (via Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu-auth-token
TWILIO_PHONE_NUMBER=+5511999999999

# ============================================
# Configurações de Busca
# ============================================
SEARXNG_URL=http://localhost:8080

# ============================================
# Configurações de Segurança
# ============================================
ALLOWED_USERS=telegram:123456789,discord:987654321
SESSION_EXPIRE_HOURS=24
MAX_REQUESTS_PER_MINUTE=60

# ============================================
# Configurações Avançadas
# ============================================
MEMORY_CONTEXT_WINDOW=10
MEMORY_SUMMARY_THRESHOLD=20
ENABLE_AUTONOMOUS_MODE=true
MAX_PARALLEL_TASKS=5
SANDBOX_EXECUTION_TIMEOUT=30
